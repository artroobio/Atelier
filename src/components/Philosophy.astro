---
// src/components/Philosophy.astro
---

<section id="philosophy" class="philosophy-section-new">
  <div class="bg-architectural"></div>
  <div class="absolute-line" id="vertical-line"></div>

  <div class="philosophy-content-wrapper">
    <span class="philosophy-tagline-new blur-reveal" id="tagline">
      01 — Websites That Feel Atmospheric
    </span>

    <h2 class="philosophy-heading-new" id="heading">
      Designed to <i class="italic-font">immerse</i>. <br/>
      Crafted to evoke <i class="italic-font">emotion</i>.
    </h2>

    <div class="glass-card-premium-new blur-reveal" id="body-card">
      <p class="philosophy-para-new" id="card-paragraph">
        We create cinematic web experiences for interior architects that inspire aspiration, curiosity, and emotional connection.
      </p>
      
      <div class="philosophy-grid-new" id="card-grid">
        <div class="reveal-item reveal-item-init">
          <div class="flex-row-center-gap">
            <div class="accent-bar"></div>
            <h4 class="sub-heading-new">Spatial Motion</h4>
          </div>
          <p class="sub-text-new">We use rhythmic movement to guide the eye and create a sense of digital depth.</p>
        </div>
        <div class="reveal-item reveal-item-init">
          <div class="flex-row-center-gap">
            <div class="accent-bar"></div>
            <h4 class="sub-heading-new">Visual Narrative</h4>
          </div>
          <p class="sub-text-new">Transforming static portfolios into living environments that tell your studio's story.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const detectMobile = () => window.matchMedia('(max-width: 768px)').matches;

  const wrapWords = (el: HTMLElement | null) => {
    if (!el) return;
    const text = el.innerHTML;
    const words = text.split(/(\s+|<br\/?>|<\/?[^>]+>)/g);
    
    el.innerHTML = words.map(word => {
      if (word.trim().length > 0 && !word.startsWith('<')) {
        return `<span class="reveal-word">${word}</span>`;
      }
      return word;
    }).join('');
  };

  const initPhilosophy = () => {
    const root = document.querySelector('#philosophy');
    if (!root) return;

    const heading = root.querySelector('#heading') as HTMLElement;
    wrapWords(heading);

    if (detectMobile()) {
      root.querySelectorAll('.reveal-word').forEach((word: any) => {
        word.style.filter = 'none';
        word.style.opacity = '1';
        word.style.transform = 'none';
      });
      root.querySelectorAll('.blur-reveal, .reveal-item').forEach((el: any) => {
        el.style.filter = 'none';
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
      const line = root.querySelector('#vertical-line') as HTMLElement;
      if (line) line.style.transform = 'scaleY(1)';
      return;
    }

    gsap.fromTo('.bg-architectural',
      { y: 0 },
      {
        y: '17%',
        ease: 'none',
        scrollTrigger: {
          trigger: root,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 0.3
        }
      }
    );

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: root,
        start: 'top 45%',
        toggleActions: 'play none none none'
      }
    });

    tl.to('#vertical-line', { scaleY: 1, duration: 2, ease: 'power4.inOut' });
    tl.to('#tagline', { opacity: 1, y: 0, duration: 1.2, ease: 'power3.out' }, '-=1.5');
    tl.to('#heading .reveal-word', {
      opacity: 1,
      y: 0,
      duration: 1.5,
      stagger: 0.04,
      ease: 'power4.out'
    }, '-=1.2');
    tl.to('#body-card', { opacity: 1, y: 0, duration: 1.2, ease: 'power3.out' }, '-=1.2');
    tl.to('.reveal-item', { opacity: 1, y: 0, duration: 0.8, stagger: 0.2, ease: 'power2.out' }, '-=0.8');
  };

  initPhilosophy();
  document.addEventListener('astro:page-load', initPhilosophy);
</script>
