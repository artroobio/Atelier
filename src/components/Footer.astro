</footer>

<style>
  .footer-root {
    background: #080808;
    color: #fff;
    font-family: 'Inter', sans-serif;
    overflow: hidden;
  }

  /* ── Top grid ── */
  .footer-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 100px 60px 80px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1.2fr;
    gap: 60px;
    align-items: flex-start;
  }

  /* Left column */
  .footer-cta {
    font-size: clamp(1.6rem, 2.8vw, 2.5rem);
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin: 0 0 36px;
  }

  .footer-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 13px 26px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 6px;
    color: #fff;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: background 0.25s, color 0.25s, border-color 0.25s;
  }

  .footer-btn:hover {
    background: #fff;
    color: #000;
    border-color: #fff;
  }

  .footer-copyright {
    margin: 56px 0 0;
    font-size: 0.75rem;
    font-weight: 300;
    opacity: 0.35;
    letter-spacing: 0.01em;
  }

  /* Middle column — nav */
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding-top: 4px;
  }

  .footer-nav a {
    color: #fff;
    text-decoration: none;
    font-size: 1.35rem;
    font-weight: 400;
    opacity: 0.65;
    transition: opacity 0.2s;
  }

  .footer-nav a:hover { opacity: 1; }

  /* Right column — connect */
  .footer-connect-label {
    font-size: 1.35rem;
    font-weight: 400;
    margin: 0 0 20px;
  }

  .footer-address {
    font-size: 0.875rem;
    font-weight: 300;
    line-height: 1.65;
    opacity: 0.55;
    margin: 0 0 36px;
  }

  .footer-socials {
    display: flex;
    gap: 18px;
  }

  .footer-socials a {
    color: #fff;
    opacity: 0.55;
    display: flex;
    transition: opacity 0.2s, transform 0.2s;
  }

  .footer-socials a:hover {
    opacity: 1;
    transform: translateY(-2px);
  }

  /* ── Big video-through-text ──
     Key technique:
     - .footer-bigtext-wrap is the container; background matches footer bg
     - video is absolute, fills the wrap
     - .footer-bigtext-mask is position:relative (NOT absolute) so it drives
       the container height naturally
     - mix-blend-mode:multiply on the mask: where the mask is dark (#080808)
       it multiplies dark × video ≈ black (hides video); where it is white
       (the text) it multiplies 1 × video = video (reveals it)
  ── */
  .footer-bigtext-wrap {
    position: relative;
    background: #080808;
    overflow: hidden;
    line-height: 0;
  }

  .footer-bigtext-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  .footer-bigtext-mask {
    position: relative;
    z-index: 1;
    mix-blend-mode: multiply;
    background: #080808;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 22vw;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 0.88;
    text-align: center;
    padding: 0.04em 0 0.06em;
    width: 100%;
    user-select: none;
    pointer-events: none;
  }

  .fbt-line {
    display: block;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer-col-left {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .footer-container {
      padding: 60px 24px 50px;
    }
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .footer-col-left {
      grid-column: span 1;
    }
    .footer-cta {
      font-size: clamp(1.4rem, 5vw, 2rem);
    }
    .footer-bigtext-mask {
      font-size: 24vw;
      letter-spacing: -0.025em;
    }
  }

  .footer-root {
    /* Removed content-visibility to prevent scrollbar flickering */
  }
</style>

<script>
  const video = document.getElementById('footer-bg-video') as HTMLVideoElement | null;
  if (video) {
    new IntersectionObserver(([e]) => {
      if (e.isIntersecting) video.play().catch(() => {});
      else video.pause();
    }, { threshold: 0.05 }).observe(video.closest('footer') as Element);
  }
</script>
