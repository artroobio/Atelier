---
// src/components/Footer.astro
---

<footer class="footer-root">

  <!-- Top info grid -->
  <div class="footer-container">
    <div class="footer-grid">

      <!-- Left: CTA -->
      <div class="footer-col-left">
        <p class="footer-cta">See how we can elevate<br/>your architectural presence.</p>
        <a href="/contact" class="footer-btn">
          Let's Talk
          <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M1 11L11 1M11 1H3M11 1V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <p class="footer-copyright">© 2026 Atelier Evo · Architectural Digital Agency</p>
      </div>

      <div class="footer-col-right">
        <p class="footer-connect-label">Explore</p>
        <nav class="footer-mini-nav">
          <a href="/">Home</a>
          <a href="/projects">Projects</a>
          <a href="/services">Services</a>
          <a href="/blog">Blog</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>

    </div>
  </div>

  <!-- Big video-through-text -->
  <div class="footer-bigtext-wrap">
    <video
      id="footer-bg-video"
      class="footer-bigtext-video"
      muted
      loop
      playsinline
      preload="none"
      src="https://assets.zyrosite.com/AGBzPMBJDQiwDGny/grey-home-interior-design-video-M13Xi8TTbaVTMRqP.mp4"
    ></video>
    <div class="footer-bigtext-mask">
      <span class="fbt-line">ATELIER</span>
      <span class="fbt-line">EVO</span>
    </div>
  </div>

</footer>

<style>
  .footer-root {
    background: #080808;
    color: #fff;
    font-family: 'Inter', sans-serif;
    overflow: hidden;
  }

  /* ── Top grid ── */
  .footer-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 100px 60px 80px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 100px;
    align-items: flex-start;
  }

  /* Left column */
  .footer-cta {
    font-size: clamp(1.6rem, 2.8vw, 2.5rem);
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin: 0 0 36px;
  }

  .footer-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 13px 26px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 6px;
    color: #fff;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: background 0.25s, color 0.25s, border-color 0.25s;
  }

  .footer-btn:hover {
    background: #fff;
    color: #000;
    border-color: #fff;
  }

  .footer-copyright {
    margin: 56px 0 0;
    font-size: 0.75rem;
    font-weight: 300;
    opacity: 0.35;
    letter-spacing: 0.01em;
  }



  .footer-col-right {
    text-align: right;
  }

  .footer-connect-label {
    font-size: 1.35rem;
    font-weight: 400;
    margin: 0 0 20px;
  }

  .footer-mini-nav {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 0;
  }

  .footer-mini-nav a {
    color: #fff;
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 300;
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .footer-mini-nav a:hover {
    opacity: 1;
  }



  /* ── Big video-through-text ──
     Key technique:
     - .footer-bigtext-wrap is the container; background matches footer bg
     - video is absolute, fills the wrap
     - .footer-bigtext-mask is position:relative (NOT absolute) so it drives
       the container height naturally
     - mix-blend-mode:multiply on the mask: where the mask is dark (#080808)
       it multiplies dark × video ≈ black (hides video); where it is white
       (the text) it multiplies 1 × video = video (reveals it)
  ── */
  .footer-bigtext-wrap {
    position: relative;
    background: #080808;
    overflow: hidden;
    line-height: 0;
  }

  .footer-bigtext-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  .footer-bigtext-mask {
    position: relative;
    z-index: 1;
    mix-blend-mode: multiply;
    background: #080808;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 22vw;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 0.88;
    text-align: center;
    padding: 0.04em 0 0.06em;
    width: 100%;
    user-select: none;
    pointer-events: none;
  }

  .fbt-line {
    display: block;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer-col-left {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .footer-container {
      padding: 60px 24px 50px;
    }
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .footer-col-left {
      grid-column: span 1;
    }
    .footer-cta {
      font-size: clamp(1.4rem, 5vw, 2rem);
    }
    .footer-bigtext-mask {
      font-size: 24vw;
      letter-spacing: -0.025em;
    }
  }

  .footer-root {
    /* Removed content-visibility to prevent scrollbar flickering */
  }
</style>

<script>
  const video = document.getElementById('footer-bg-video') as HTMLVideoElement | null;
  if (video) {
    new IntersectionObserver(([e]) => {
      if (e.isIntersecting) video.play().catch(() => {});
      else video.pause();
    }, { threshold: 0.05 }).observe(video.closest('footer') as Element);
  }
</script>
