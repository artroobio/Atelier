---
// src/components/JellyGallery.astro
const projects = [
  {
    category: 'Glass · Residential',
    year: '2024',
    title: 'Prismatic Void',
    img: '/luxury_interior_vertical_1_1778345968849.png',
    pill: 'Explore',
  },
  {
    category: 'Obsidian · Commercial',
    year: '2023',
    title: 'Dark Matter',
    img: '/commercial_premium_office_1778344233441.png',
    pill: 'View',
  },
  {
    category: 'Light · Cultural',
    year: '2023',
    title: 'Luminous Frame',
    img: '/cultural_glass_museum_1778344274605.png',
    pill: 'Discover',
  },
  {
    category: 'Void · Hospitality',
    year: '2022',
    title: 'Negative Space',
    img: '/hospitality_luxury_hotel_1778344259267.png',
    pill: 'Enter',
  },
];
---

<section id="jelly-gallery-root" class="jelly-section">
  <div class="jelly-shell">

    <div class="jelly-header">
      <h2 class="jelly-heading">All about the optics.<br/>All about the <i>perception</i>.</h2>
    </div>

    <div class="jelly-grid">
      {projects.map((p) => (
        <div class="jelly-card">
          <div class="jelly-image-wrapper">
            <img
              src={p.img}
              alt={p.title}
              class="jelly-img"
              loading="lazy"
              decoding="async"
            />
            <span class="jelly-pill">{p.pill} —</span>
          </div>
          <div class="jelly-card-details">
            <span class="jelly-tag">{p.category} · {p.year}</span>
            <h3 class="jelly-title">{p.title}</h3>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  let _jellyTriggers: ScrollTrigger[] = [];

  const wrapChars = (el: HTMLElement | null): NodeListOf<HTMLElement> | HTMLElement[] => {
    if (!el) return [];
    const text = el.innerText;
    el.setAttribute('aria-label', text);
    el.innerHTML = text
      .split('')
      .map(char => {
        if (char === '\n') return '<br/>';
        if (char === ' ') return '<span style="display:inline-block;white-space:pre"> </span>';
        return `<span class="jelly-char" style="display:inline-block">${char}</span>`;
      })
      .join('');
    return el.querySelectorAll<HTMLElement>('.jelly-char');
  };

  const initJellyGallery = () => {
    _jellyTriggers.forEach(st => st.kill());
    _jellyTriggers = [];
    const _before = new Set(ScrollTrigger.getAll());
    const cards = document.querySelectorAll<HTMLElement>('.jelly-card');
    const mainHeading = document.querySelector<HTMLElement>('.jelly-heading');
    if (!cards.length) return;

    const isMobile = window.matchMedia('(max-width: 768px)').matches;

    if (mainHeading && !isMobile) {
      const headingChars = wrapChars(mainHeading);
      gsap.fromTo(headingChars,
        { opacity: 0, y: 25 },
        {
          opacity: 1,
          y: 0,
          duration: 1.8,
          stagger: 0.04,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: mainHeading,
            start: 'top 90%',
            toggleActions: 'play none none reverse'
          }
        }
      );
    }

    cards.forEach(card => {
      const wrapper = card.querySelector<HTMLElement>('.jelly-image-wrapper');
      const img     = card.querySelector<HTMLElement>('.jelly-img');
      const titleEl = card.querySelector<HTMLElement>('.jelly-title');

      // Don't re-split if already split
      const chars = titleEl?.querySelector('.jelly-char')
        ? titleEl.querySelectorAll<HTMLElement>('.jelly-char')
        : wrapChars(titleEl);

      if (isMobile) {
        if (wrapper) gsap.set(wrapper, { clipPath: 'none', opacity: 1 });
        if (img)     gsap.set(img,     { scale: 1 });
        chars.forEach(c => { c.style.opacity = '1'; c.style.transform = 'none'; });
        return;
      }

      // clipPath wipe: no nested scale conflict, no overshoot repaint
      gsap.set(wrapper, { clipPath: 'inset(100% 0% 0% 0% round 1.5rem 1.5rem 0 0)', opacity: 1 });
      gsap.set(img,     { scale: 1.08, transformOrigin: 'center center', transition: 'none' });
      gsap.set(chars,   { opacity: 0, y: 15 });

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: card,
          start: 'top 88%',
          toggleActions: 'play none none reverse',
        },
        onStart: () => {
          (wrapper as HTMLElement).style.willChange = 'clip-path';
          (img as HTMLElement).style.willChange = 'transform';
        },
        onComplete: () => {
          (wrapper as HTMLElement).style.willChange = 'auto';
          (img as HTMLElement).style.willChange = 'auto';
        },
      });

      tl.to(wrapper, {
        clipPath: 'inset(0% 0% 0% 0%)',
        duration: 1.1,
        ease: 'expo.out',
      })
      .to(img, {
        scale: 1,
        duration: 1.4,
        ease: 'power3.out',
      }, '<')
      .to(chars, {
        opacity: 1,
        y: 0,
        stagger: 0.035,
        duration: 0.9,
      }, '-=0.7');
    });

    _jellyTriggers = ScrollTrigger.getAll().filter(st => !_before.has(st));
  };

  function scheduleJelly() {
    const section = document.querySelector('#jelly-gallery-root');
    if (!section) return;
    let done = false;
    new IntersectionObserver((entries, obs) => {
      if (entries[0].isIntersecting && !done) {
        done = true;
        obs.disconnect();
        initJellyGallery();
      }
    }, { rootMargin: '300px 0px' }).observe(section);
  }

  scheduleJelly();
  document.addEventListener('astro:page-load', scheduleJelly);
</script>
