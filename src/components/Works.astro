---
// src/components/Works.astro
const segments = [
  {
    title: 'Beyond the <i class="italic font-light">Screen</i>.',
    tagline: '01 — Experience',
    cardTitle: 'Digital Atmosphere',
    cardDesc: 'A website should feel immersive, atmospheric, and emotionally engaging. We create digital experiences that draw visitors into the world of your studio through motion, clarity, and cinematic presentation.',
    cardTag: 'The Vision'
  },
  {
    title: 'Designed to <i class="italic font-light">Immerse</i>.',
    tagline: '02 — Interaction',
    cardTitle: 'Cinematic Motion',
    cardDesc: 'Through cinematic motion, layered visuals, and fluid interaction, we transform websites into experiences that feel immersive, emotional, and spatial.',
    cardTag: 'The Motion'
  },
  {
    title: 'Crafted for <i class="italic font-light">Interior Architects</i>.',
    tagline: '03 — Specialization',
    cardTitle: 'Visual Identity',
    cardDesc: 'Every layout, transition, and detail is designed to showcase interiors with clarity, elegance, and a strong sense of visual identity.',
    cardTag: 'The Detail'
  },
  {
    title: 'More Than a <i class="italic font-light">Portfolio</i>.',
    tagline: '04 — Connection',
    cardTitle: 'Aspirational Design',
    cardDesc: 'A beautifully designed website creates aspiration and emotional connection — allowing visitors to feel the world your studio creates before they ever step inside it.',
    cardTag: 'The Impact'
  }
];
---

<section id="works-section-root">
  <div class="video-hero-container">
    <video class="video-bg-works" muted loop playsinline preload="none">
      <source src="https://assets.zyrosite.com/AGBzPMBJDQiwDGny/grey-home-interior-design-video-M13Xi8TTbaVTMRqP.mp4" type="video/mp4" />
    </video>

    <div id="works-text-overlay" class="cinematic-text-overlay pos-tl text-white">
      <span class="block tagline-span" style="font-family: 'Inter'; font-weight: 600; font-size: 12px; letter-spacing: 0.6em; text-transform: uppercase; margin-bottom: 24px; opacity: 0.6;">
        {segments[0].tagline}
      </span>
      <h1 id="works-title" class="works-hero-title" set:html={segments[0].title}></h1>
    </div>

    <div id="works-card-overlay" class="glass-morphism-card pos-br text-white">
      <span class="card-tag-span" style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.3em; margin-bottom: 12px; display: block; font-weight: 600; opacity: 0.6;">
        {segments[0].cardTag}
      </span>
      <h3 class="card-title-h3" style="font-family: 'Playfair Display'; font-size: 1.875rem; margin-bottom: 16px; font-style: italic; color: #fff;">
        {segments[0].cardTitle}
      </h3>
      <p class="card-desc-p" style="font-size: 0.875rem; font-weight: 300; line-height: 1.625; opacity: 0.8; color: #fff;">
        {segments[0].cardDesc}
      </p>
      <div style="margin-top: 32px; padding-top: 16px; border-top: 1px solid rgba(255, 255, 255, 0.2);">
        <a href="#" style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.4em; opacity: 0.6; transition: opacity 0.3s; text-decoration: none; color: #fff;">
          Explore Detail —
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const segments = [
    {
      title: 'Beyond the <i class="italic font-light">Screen</i>.',
      tagline: '01 — Experience',
      cardTitle: 'Digital Atmosphere',
      cardDesc: 'A website should feel immersive, atmospheric, and emotionally engaging. We create digital experiences that draw visitors into the world of your studio through motion, clarity, and cinematic presentation.',
      cardTag: 'The Vision'
    },
    {
      title: 'Designed to <i class="italic font-light">Immerse</i>.',
      tagline: '02 — Interaction',
      cardTitle: 'Cinematic Motion',
      cardDesc: 'Through cinematic motion, layered visuals, and fluid interaction, we transform websites into experiences that feel immersive, emotional, and spatial.',
      cardTag: 'The Motion'
    },
    {
      title: 'Crafted for <i class="italic font-light">Interior Architects</i>.',
      tagline: '03 — Specialization',
      cardTitle: 'Visual Identity',
      cardDesc: 'Every layout, transition, and detail is designed to showcase interiors with clarity, elegance, and a strong sense of visual identity.',
      cardTag: 'The Detail'
    },
    {
      title: 'More Than a <i class="italic font-light">Portfolio</i>.',
      tagline: '04 — Connection',
      cardTitle: 'Aspirational Design',
      cardDesc: 'A beautifully designed website creates aspiration and emotional connection — allowing visitors to feel the world your studio creates before they ever step inside it.',
      cardTag: 'The Impact'
    }
  ];

  const detectMobile = () => window.matchMedia('(max-width: 768px)').matches;

  const wrapWords = (el: HTMLElement | null) => {
    if (!el) return;
    const text = el.innerHTML;
    const words = text.split(/(\s+|<br\/?>|<\/?[^>]+>)/g);
    el.innerHTML = words.map(word => {
      if (word.trim().length > 0 && !word.startsWith('<')) {
        return `<span class="reveal-word">${word}</span>`;
      }
      return word;
    }).join('');
  };

  const initWorks = () => {
    const root = document.querySelector('#works-section-root');
    const titleEl = document.querySelector('#works-title');
    const textOverlay = document.querySelector('#works-text-overlay');
    const cardOverlay = document.querySelector('#works-card-overlay');

    if (!root || !titleEl || !textOverlay || !cardOverlay) return;

    // Play/pause video only when section is in the viewport — avoids eager decode off-screen
    const video = root.querySelector('.video-bg-works') as HTMLVideoElement | null;
    if (video) {
      new IntersectionObserver(([e]) => {
        if (e.isIntersecting) video.play().catch(() => {});
        else video.pause();
      }, { threshold: 0.05 }).observe(root as HTMLElement);
    }

    if (detectMobile()) {
      root.classList.add('works-static');
      return;
    }

    wrapWords(titleEl);

    ScrollTrigger.create({
      trigger: root,
      start: "top top",
      end: "+=185%",
      pin: true,
      pinSpacing: true
    });

    gsap.to(titleEl.querySelectorAll('.reveal-word'), {
      filter: "blur(0px)",
      opacity: 1,
      y: 0,
      duration: 1.5,
      stagger: 0.08,
      ease: "power3.out",
      scrollTrigger: {
        trigger: root,
        start: "top 60%"
      }
    });

    let currentIndex = 0;
    const masterTimeline = gsap.timeline({ repeat: -1, paused: true });

    segments.forEach((_, i) => {
      masterTimeline.to({}, { duration: 3.5 }); 

      masterTimeline.to([textOverlay, cardOverlay], {
        opacity: 0,
        scale: 0.95,
        filter: "blur(20px)",
        duration: 0.8,
        ease: "power2.inOut",
        onStart: () => {
          (textOverlay as HTMLElement).style.willChange = 'filter, opacity, transform';
          (cardOverlay as HTMLElement).style.willChange = 'filter, opacity, transform';
        },
        onComplete: () => {
          currentIndex = (i + 1) % segments.length;
          const data = segments[currentIndex];
          
          // Update Content
          const taglineSpan = textOverlay.querySelector('.tagline-span');
          const titleH1 = textOverlay.querySelector('#works-title');
          const cardTagSpan = cardOverlay.querySelector('.card-tag-span');
          const cardTitleH3 = cardOverlay.querySelector('.card-title-h3');
          const cardDescP = cardOverlay.querySelector('.card-desc-p');

          if (taglineSpan) taglineSpan.innerText = data.tagline;
          if (titleH1) titleH1.innerHTML = data.title;
          if (cardTagSpan) cardTagSpan.innerText = data.cardTag;
          if (cardTitleH3) cardTitleH3.innerText = data.cardTitle;
          if (cardDescP) cardDescP.innerText = data.cardDesc;

          // Swap positions logic
          if (window.innerWidth > 900 && currentIndex % 2 !== 0) {
            textOverlay.className = "cinematic-text-overlay pos-br text-white";
            cardOverlay.className = "glass-morphism-card pos-tl text-white";
          } else {
            textOverlay.className = "cinematic-text-overlay pos-tl text-white";
            cardOverlay.className = "glass-morphism-card pos-br text-white";
          }

          // Delay matches React version's setTimeout(50) — ensures innerHTML is committed before wrapWords
          setTimeout(() => {
            if (!titleH1) return;
            wrapWords(titleH1);
            gsap.fromTo(titleH1.querySelectorAll('.reveal-word'),
              { opacity: 0, y: 15, filter: 'blur(10px)' },
              { opacity: 1, y: 0, filter: 'blur(0px)', duration: 1.0, stagger: 0.04, ease: 'power2.out' }
            );
          }, 50);
        }
      });

      masterTimeline.to([textOverlay, cardOverlay], {
        opacity: 1,
        scale: 1,
        filter: "blur(0px)",
        duration: 0.8,
        ease: "power2.out",
        onComplete: () => {
          (textOverlay as HTMLElement).style.willChange = 'auto';
          (cardOverlay as HTMLElement).style.willChange = 'auto';
        }
      });
    });

    // Pause the cycling animation when the section is fully scrolled past
    new IntersectionObserver(([e]) => {
      if (e.isIntersecting) masterTimeline.play();
      else masterTimeline.pause();
    }, { threshold: 0.05 }).observe(root as HTMLElement);
  };

  initWorks();
  document.addEventListener('astro:page-load', initWorks);
</script>
