---
// src/components/Gallery.astro
---

<section id="gallery-section" class="gallery-section">
  <div class="gallery-grid">
    <div class="gallery-text-overlay top-center">
      <h2 class="gallery-main-title">THE DIGITAL ATELIER</h2>
    </div>
    <!-- Top Row: 3 Vertical Panels -->
    <div class="gallery-row top-row">
      <div class="gallery-item vertical">
        <img src="/luxury_interior_vertical_1_1778345968849.png" alt="Luxury Interior 1" />
        <div class="item-info-box">
          <span class="info-label">RESIDENTIAL</span>
          <h3 class="info-title">Living Sanctuary</h3>
        </div>
      </div>
      <div class="gallery-item vertical">
        <img src="/luxury_interior_vertical_2_1778345994720.png" alt="Luxury Interior 2" />
        <div class="item-info-box">
          <span class="info-label">PRIVATE</span>
          <h3 class="info-title">Luminous Retreat</h3>
        </div>
      </div>
      <div class="gallery-item vertical">
        <img src="/luxury_interior_vertical_3_1778346010645.png" alt="Luxury Interior 3" />
        <div class="item-info-box">
          <span class="info-label">WELLNESS</span>
          <h3 class="info-title">Elemental Bath</h3>
        </div>
      </div>
    </div>

    <!-- Bottom Row: 2 Horizontal Panels with Text Overlay -->
    <div class="gallery-row bottom-row">
      <div class="gallery-item horizontal">
        <img src="/luxury_interior_horizontal_1_1778346028371.png" alt="Luxury Interior 4" />
        <div class="item-info-box">
          <span class="info-label">PANORAMIC</span>
          <h3 class="info-title">The Vista Lounge</h3>
        </div>
      </div>
      <div class="gallery-item horizontal">
        <img src="/luxury_interior_horizontal_2_1778346049970.png" alt="Luxury Interior 5" />
        <div class="item-info-box">
          <span class="info-label">CULINARY</span>
          <h3 class="info-title">Gourmet Atelier</h3>
        </div>
      </div>

      <div class="gallery-text-overlay">
        <div class="gallery-sub-info">
          <p>CURATED FOR THE MODERN COLLECTOR.<br />UNCOMPROMISING PRECISION IN EVERY DETAIL.</p>
          <div class="gallery-links">
            <a href="#">DISCOVER MORE</a>
            <a href="#">THE COLLECTION</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const detectMobile = () => window.matchMedia('(max-width: 768px)').matches;

  const initGallery = () => {
    const section = document.querySelector('.gallery-section') as HTMLElement;
    const grid = document.querySelector('.gallery-grid') as HTMLElement;

    if (!section || !grid) return;

    if (detectMobile()) {
      gsap.set(grid, { scale: 1, opacity: 1, borderRadius: '0px' });
      gsap.set('.gallery-sub-info', { opacity: 1, y: 0, filter: 'none' });
      gsap.set('.item-info-box', { opacity: 1, y: 0, scale: 1, filter: 'none' });
      gsap.set('.gallery-main-title', { opacity: 1 });
      return;
    }

    const wrapChars = (el: HTMLElement | null): NodeListOf<HTMLElement> | HTMLElement[] => {
      if (!el) return [];
      const text = el.innerText;
      el.setAttribute('aria-label', text);
      el.innerHTML = text
        .split('')
        .map(char => {
          if (char === ' ') return '<span style="display:inline-block;white-space:pre"> </span>';
          return `<span class="gallery-char" style="display:inline-block">${char}</span>`;
        })
        .join('');
      return el.querySelectorAll<HTMLElement>('.gallery-char');
    };

    const mainTitle = document.querySelector('.gallery-main-title') as HTMLElement;
    if (mainTitle) {
      const chars = wrapChars(mainTitle);
      gsap.fromTo(chars, 
        { opacity: 0, y: 40, filter: 'blur(20px)' },
        { 
          opacity: 1, 
          y: 0, 
          filter: 'blur(0px)', 
          duration: 1.0, 
          stagger: 0.03, 
          ease: 'power3.out',
          scrollTrigger: {
            trigger: mainTitle,
            start: 'top 85%',
            toggleActions: 'play none none reverse'
          }
        }
      );
    }

    // Grid scale-in + border-radius reveal scrubbed together as user scrolls in
    gsap.fromTo(grid,
      { scale: 0.85, opacity: 0.5, borderRadius: '40px' },
      {
        scale: 1, opacity: 1, borderRadius: '0px', ease: 'none',
        scrollTrigger: {
          trigger: section,
          start: 'top bottom',
          end: 'top top',
          scrub: 1,
        }
      }
    );

    // Fade-in without blur — fewer compositing layers
    gsap.fromTo('.gallery-sub-info',
      { y: 30, opacity: 0 },
      {
        y: 0, opacity: 1, duration: 1.4, ease: 'expo.out',
        scrollTrigger: { trigger: section, start: 'top 98%', toggleActions: 'play none none none' }
      }
    );

    gsap.fromTo('.item-info-box',
      { y: 20, opacity: 0 },
      {
        y: 0, opacity: 1, duration: 1.0, stagger: 0.08, ease: 'power3.out',
        scrollTrigger: { trigger: section, start: 'top 95%', toggleActions: 'play none none none' }
      }
    );

    // Promote images to GPU layers only while in view
    const imgs = gsap.utils.toArray<HTMLElement>('.gallery-item img');
    ScrollTrigger.create({
      trigger: section,
      start: 'top bottom',
      end: 'bottom top',
      onEnter: () => imgs.forEach(img => { img.style.willChange = 'transform'; }),
      onLeave: () => imgs.forEach(img => { img.style.willChange = 'auto'; }),
      onEnterBack: () => imgs.forEach(img => { img.style.willChange = 'transform'; }),
      onLeaveBack: () => imgs.forEach(img => { img.style.willChange = 'auto'; }),
    });

    // Reduced parallax travel (40px) with scrub:1 buffer
    imgs.forEach(img => {
      gsap.fromTo(img,
        { y: -20 },
        {
          y: 20, ease: 'none',
          scrollTrigger: { trigger: img, start: 'top bottom', end: 'bottom top', scrub: 1 }
        }
      );
    });
  };

  initGallery();
  document.addEventListener('astro:page-load', initGallery);
</script>
