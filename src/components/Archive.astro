---
// src/components/Archive.astro
const projectData = [
  { id: 0, year: '2024', name: 'Obsidian House',  loc: 'Zurich, CH',    tag: 'obsidian', img: '/obsidian_house.png', desc: 'A residence carved from dark stone, where light is treated as material.' },
  { id: 1, year: '2023', name: 'Glass Pavilion',  loc: 'Kyoto, JP',     tag: 'glass',    img: '/glass_pavilion.png', desc: 'Merging traditional aesthetics with total transparency.' },
  { id: 2, year: '2023', name: 'Void Tower',      loc: 'Berlin, DE',    tag: 'void',     img: '/void_tower.png', desc: 'A vertical exploration of negative space silhouettes.' },
  { id: 3, year: '2022', name: 'Crystal Gallery', loc: 'New York, US',  tag: 'glass',    img: '/crystal_gallery.png', desc: 'A museum where every surface refracts the city motion.' },
  { id: 4, year: '2022', name: 'The Prism',       loc: 'London, UK',    tag: 'light',    img: '/the_prism.png', desc: 'Atmospheric volume through multi-layered glass facades.' },
  { id: 5, year: '2021', name: 'Basalt Studio',   loc: 'Reykjavik, IS', tag: 'obsidian', img: '/basalt_studio.png', desc: 'Subterranean creative studio in volcanic rock.' },
];

const filters = ['all', 'glass', 'obsidian', 'light', 'void'];
---

<section id="archive-grid-root">
  <div class="archive-shell">

    <div class="archive-header">
      <div class="archive-header-copy">
        <span class="archive-kicker">The Archive</span>
        <h2 class="archive-title">Ledger of <i>Void</i>.</h2>
      </div>
      <div class="archive-filters">
        {filters.map((tag) => (
          <button
            class={`filter-btn${tag === 'all' ? ' active' : ''}`}
            data-filter={tag}
            type="button"
          >
            {tag === 'all' ? 'All Works' : tag}
          </button>
        ))}
      </div>
    </div>

    <div id="archive-project-grid" class="archive-letterbox-list">
      {projectData.map((project) => (
        <div
          class="archive-letterbox-item"
          data-tag={project.tag}
        >
          <div class="archive-lb-image-wrap">
            <img
              src={project.img}
              alt={project.name}
              class="archive-lb-image"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="archive-lb-info">
            <div class="archive-lb-top">
              <span class="archive-lb-meta">{project.year} — {project.tag}</span>
              <h3 class="archive-lb-name">{project.name}</h3>
              <p class="archive-lb-desc">{project.desc}</p>
            </div>
            <div class="archive-lb-bottom">
              <span class="archive-lb-meta">{project.loc}</span>
              <span class="archive-lb-cta">View Case —</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="archive-footer">
      <span>©2026 Atelier Transparent / Systems</span>
      <a href="#">Request Full Ledger</a>
    </div>

  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const initArchive = () => {
    const section = document.querySelector('#archive-grid-root') as HTMLElement;
    if (!section) return;

    const items = () => document.querySelectorAll<HTMLElement>('.archive-letterbox-item');
    const filterBtns = document.querySelectorAll<HTMLElement>('.filter-btn');

    // GSAP owns the initial hidden state — not CSS
    gsap.set(items(), { opacity: 0, y: 30 });

    // Entry reveal — fires once on scroll into view
    ScrollTrigger.create({
      trigger: section,
      start: 'top 80%',
      onEnter: () => {
        gsap.to(items(), { opacity: 1, y: 0, duration: 1.0, stagger: 0.07, ease: 'power3.out' });
      },
    });

    // Filter
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const tag = btn.dataset.filter;

        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const visible: HTMLElement[] = [];
        const hidden: HTMLElement[] = [];

        items().forEach(item => {
          if (tag === 'all' || item.dataset.tag === tag) {
            visible.push(item);
          } else {
            hidden.push(item);
          }
        });

        // Fade out hidden, then show/animate visible
        const tl = gsap.timeline();

        if (hidden.length) {
          tl.to(hidden, { opacity: 0, y: -10, duration: 0.25, stagger: 0.02, ease: 'power2.in',
            onComplete: () => hidden.forEach(el => { el.style.display = 'none'; })
          });
        }

        visible.forEach(el => { el.style.display = 'flex'; });

        tl.fromTo(visible,
          { opacity: 0, y: 20 },
          { opacity: 1, y: 0, duration: 0.6, stagger: 0.05, ease: 'power3.out' }
        );
      });
    });
  };

  initArchive();
  document.addEventListener('astro:page-load', initArchive);
</script>
