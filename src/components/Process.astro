---
// src/components/Process.astro
const panels = [
  {
    id: '01',
    label: 'Atmosphere',
    title: 'First <i class="italic font-light">Impression</i>.',
    text: 'A website is experienced before it is understood. We shape atmosphere, pacing, and visual emotion from the very first frame.',
    image: '/images/process_1.png',
    alt: 'Impression',
  },
  {
    id: '02',
    label: 'Interaction',
    title: 'Spatial <i class="italic font-light">Motion</i>.',
    text: 'Movement creates immersion. Through cinematic transitions, layered depth, and fluid interactions, digital spaces begin to feel architectural.',
    image: '/images/process_2.png',
    alt: 'Motion',
  },
  {
    id: '03',
    label: 'Precision',
    title: 'Material & <i class="italic font-light">Detail</i>.',
    text: 'Typography, texture, light, and composition are refined with precision. Every element is designed to reflect the character of the studio behind it.',
    image: '/images/process_3.png',
    alt: 'Detail',
  },
  {
    id: '04',
    label: 'Experience',
    title: 'Digital <i class="italic font-light">Atmosphere</i>.',
    text: 'The final experience feels intuitive, immersive, and alive — a digital environment crafted to showcase interiors with clarity and emotion.',
    image: '/images/digital_atmosphere.png',
    alt: 'Experience',
  },
];
---

<section id="process-section-root">
  <div class="bg-grid"></div>

  <div class="progress-track">
    <div class="progress-bar"></div>
  </div>

  <div class="horizontal-container">
    {panels.map((panel) => (
      <section class="process-panel">
        <span class="panel-number">{panel.id}</span>
        <div class="process-panel-inner">
          <div class="process-copy-column">
            <span class="process-label">{panel.label}</span>
            <h2
              class="process-title"
              data-html={panel.title}
              set:html={panel.title}
            ></h2>
            <div class="glass-annotation">
              <p class="process-annotation-text">
                {panel.text}
              </p>
            </div>
          </div>
          <div class="process-media-column">
            <div class="process-image-wrap interactive-card">
              {panel.video ? (
                <video
                  class="main-process-media"
                  autoplay
                  muted
                  loop
                  playsinline
                >
                  <source src={panel.video} type="video/mp4" />
                </video>
              ) : (
                <img class="main-process-media" src={panel.image} alt={panel.alt} />
              )}
            </div>
          </div>
        </div>
      </section>
    ))}
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const detectMobile = () => window.matchMedia('(max-width: 768px)').matches;

  const wrapWords = (el: HTMLElement | null) => {
    if (!el) return;
    const text = el.innerHTML;
    const words = text.split(/(\s+|<br\/?>|<\/?[^>]+>)/g);
    el.innerHTML = words
      .map((word) => {
        if (word.trim().length > 0 && !word.startsWith('<')) {
          return `<span class="reveal-word">${word}</span>`;
        }
        return word;
      })
      .join('');
  };

  const initProcess = () => {
    const root = document.querySelector('#process-section-root') as HTMLElement;
    if (!root) return;

    if (detectMobile()) {
      root.querySelectorAll('.process-title').forEach((title: any) => {
        title.innerHTML = title.dataset.html || title.innerHTML;
      });
      root.querySelectorAll('.glass-annotation, .process-image-wrap').forEach((el: any) => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
      return;
    }

    const container = root.querySelector('.horizontal-container') as HTMLElement;
    const progressBar = root.querySelector('.progress-bar') as HTMLElement;
    const sectionPanels = gsap.utils.toArray('.process-panel');

    sectionPanels.forEach((panel: any) => {
      const title = panel.querySelector('.process-title');
      wrapWords(title);
    });

    const scrollTween = gsap.to(container, {
      x: () => -(container.scrollWidth - window.innerWidth),
      ease: 'none',
      scrollTrigger: {
        trigger: root,
        pin: true,
        scrub: 0.8,
        start: 'top top',
        end: () => `+=${container.scrollWidth}`,
        onUpdate: (self) => {
          progressBar.style.width = `${self.progress * 100}%`;
        },
      },
    });

    sectionPanels.forEach((panel: any, index: number) => {
      const titleWords = panel.querySelectorAll('.reveal-word');
      const annotation = panel.querySelector('.glass-annotation');
      const imageWrap = panel.querySelector('.process-image-wrap');
      const startTrigger = index === 0 ? 'left 120%' : 'left 65%';

      gsap.timeline({
        scrollTrigger: {
          trigger: panel,
          containerAnimation: scrollTween,
          start: startTrigger,
          toggleActions: 'play none none reverse',
        },
      })
        .fromTo(
          titleWords,
          { opacity: 0, y: 30, filter: 'blur(15px)' },
          { opacity: 1, y: 0, filter: 'blur(0px)', duration: 1, stagger: 0.05, ease: 'power4.out' }
        )
        .fromTo(
          annotation,
          { opacity: 0, x: 30, y: 10 },
          { opacity: 1, x: 0, y: 0, duration: 1.2, ease: 'power3.out' },
          '-=0.6'
        )
        .fromTo(
          imageWrap,
          { scale: 1.1, opacity: 0, x: -50 },
          { scale: 1, opacity: 1, x: 0, duration: 1.5, ease: 'expo.out' },
          '-=1.2'
        );
    });
  };

  initProcess();
  document.addEventListener('astro:page-load', initProcess);
</script>
