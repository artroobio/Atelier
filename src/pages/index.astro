---
// src/pages/index.astro
import '../styles/hero.css';
import Hero from '../components/Hero.jsx';
import Gallery from '../components/Gallery.astro';
import Philosophy from '../components/Philosophy.astro';
import Works from '../components/Works.astro';
import Process from '../components/Process.astro';
import Archive from '../components/Archive.astro';
import Accordion from '../components/Accordion.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>Atelier Transparent | Structure & Transparency</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://assets.zyrosite.com" crossorigin>
    <link rel="preconnect" href="https://ik.imagekit.io" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap"></noscript>

    <!-- Preload critical assets -->
    <link rel="preload" href="https://assets.zyrosite.com/A3QlOV94WLSaL6xE/shot-panoramic-composition-library-vfOqabRkgVEFwqi9.jpg" as="image" />
  </head>
  <body class="bg-[#f2f2f2] text-[#1a1a1a]">
    <!-- Hero Section -->
    <div class="hero-slot">
      <Hero client:only="react" />
    </div>

    <!-- The rest are static Astro components with vanilla JS scripts -->
    <Gallery />
    
    <div class="philosophy-slot">
      <Philosophy />
    </div>

    <Works />
    <Process />
    <Archive />
    <Accordion />

    <script>
      import Lenis from 'lenis';
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      let lenisInstance: Lenis | null = null;
      let gsapTickerId: ((time: number) => void) | null = null;

      function initLenis() {
        // Teardown any previous instance cleanly
        if (gsapTickerId !== null) {
          gsap.ticker.remove(gsapTickerId);
          gsapTickerId = null;
        }
        if (lenisInstance) {
          lenisInstance.destroy();
          lenisInstance = null;
        }

        lenisInstance = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
          wrapper: window,
          content: document.documentElement,
        });

        // Drive Lenis via GSAP ticker so both share the same RAF loop
        gsapTickerId = (time: number) => {
          lenisInstance!.raf(time * 1000);
          ScrollTrigger.update();
        };
        gsap.ticker.add(gsapTickerId);
        gsap.ticker.lagSmoothing(0);

        ScrollTrigger.refresh();
      }

      // Fires on initial hard load
      document.addEventListener('DOMContentLoaded', initLenis);
      // Fires on subsequent Astro View Transition navigations (no-op in MPA mode)
      document.addEventListener('astro:page-load', initLenis);
    </script>
  </body>
</html>

<style is:global>
  /* Required by Lenis — document must scroll naturally */
  html {
    height: auto;
    scroll-behavior: auto; /* Let Lenis own scrolling — no CSS smooth-scroll conflict */
  }

  /* Lenis overrides — prevent double-smooth from CSS + JS */
  html.lenis,
  html.lenis body {
    height: auto;
  }

  .lenis.lenis-smooth {
    scroll-behavior: auto !important;
  }

  .lenis.lenis-smooth [data-lenis-prevent] {
    overscroll-behavior: contain;
  }

  .lenis.lenis-stopped {
    overflow: hidden;
  }

  /* Compositor hint for the horizontal scroll container only */
  .horizontal-container {
    transform: translateZ(0);
  }

  /* Subpixel text rendering */
  * {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
</style>
