---
// src/pages/index.astro
import '../styles/hero.css';
import Hero from '../components/Hero.jsx';
import Gallery from '../components/Gallery.astro';
import JellyGallery from '../components/JellyGallery.astro';
import Philosophy from '../components/Philosophy.astro';
import Works from '../components/Works.astro';
import Process from '../components/Process.astro';
import Archive from '../components/Archive.astro';
import Accordion from '../components/Accordion.astro';
import Footer from '../components/Footer.astro';
import LenisScroll from '../components/LenisScroll.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>Atelier Evo | Structure & Transparency</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://assets.zyrosite.com" crossorigin>
    <link rel="preconnect" href="https://ik.imagekit.io" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Michroma&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Michroma&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap"></noscript>

    <!-- Preload critical assets -->
    <link rel="preload" href="https://assets.zyrosite.com/A3QlOV94WLSaL6xE/shot-panoramic-composition-library-vfOqabRkgVEFwqi9.jpg" as="image" />
    <link rel="preload" href="https://assets.zyrosite.com/A3QlOV94WLSaL6xE/modern-office-space-with-futuristic-decor-furniture-tWDr3G3kPWyBeBbj.jpg" as="image" />
  </head>
  <body class="bg-[#f2f2f2] text-[#1a1a1a]">
    <!-- Hero Section -->
    <div class="hero-slot">
      <Hero client:only="react" />
    </div>

    <!-- The rest are static Astro components with vanilla JS scripts -->
    <Gallery />
    <Process />
    <JellyGallery />

    <div class="philosophy-slot">
      <Philosophy />
    </div>

    <Works />
    <Archive />
    <Accordion />
    <Footer />
    
    <LenisScroll />

<style is:global>
  /* Compositor hint for the horizontal scroll container only */
  .horizontal-container {
    transform: translateZ(0);
  }

  /* Subpixel text rendering */
  * {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

</style>
