---
// src/pages/services.astro
import ServicesHorizontal from '../components/ServicesHorizontal.astro';
import SecondaryNav from '../components/SecondaryNav.jsx';
import Footer from '../components/Footer.astro';
import LenisScroll from '../components/LenisScroll.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Services | Atelier Evo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;900&family=Michroma&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;900&family=Michroma&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap"></noscript>
  </head>

  <body>
    <SecondaryNav client:load />
    
    <main>
      <ServicesHorizontal />
    </main>

    <Footer />
    
    <LenisScroll />
  </body>
</html>

<style is:global>
  html {
    height: auto;
    overflow-x: hidden;
  }

  /* Standard native scroll behavior */

  * {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
</style>

<style>
  html, body {
    margin: 0;
    padding: 0;
    background: #010a0a;
    color: #fff;
    font-family: 'Inter', sans-serif;
  }

  /* Removed body { overflow: hidden; } to allow Lenis scroll */
</style>
