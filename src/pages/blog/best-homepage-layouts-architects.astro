    <script>
        import { gsap } from 'gsap';
        import { ScrollTrigger } from 'gsap/ScrollTrigger';

        gsap.registerPlugin(ScrollTrigger);

        // ── Hero content fades on scroll ──
        gsap.to('.hero-content', {
            opacity: 0, y: -60, ease: 'none',
            scrollTrigger: { trigger: '#post-hero', start: 'top top', end: '60% top', scrub: true }
        });

        // ── Hero entrance ──
        const heroTl = gsap.timeline({ delay: 0.2 });
        heroTl
            .to('#hero-eyebrow',  { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' })
            .to('#hero-title',    { opacity: 1, y: 0, duration: 1,   ease: 'power3.out' }, '-=0.4')
            .to('#hero-subtitle', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, '-=0.5')
            .to('#hero-scroll',   { opacity: 1,        duration: 0.6, ease: 'power2.out' }, '-=0.3');

        gsap.to('#hero-scroll', { opacity: 0.3, repeat: -1, yoyo: true, duration: 1.4, ease: 'sine.inOut', delay: 2 });

        // ── Section headings ──
        (gsap.utils.toArray('.section-heading') as Element[]).forEach(el => {
            gsap.to(el, {
                opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
                scrollTrigger: { trigger: el as HTMLElement, start: 'top 88%' }
            });
        });

        // ── Takeaways & data points ──
        (gsap.utils.toArray('.takeaways, .data-point') as Element[]).forEach(el => {
            gsap.to(el, {
                opacity: 1, y: 0, duration: 0.7, ease: 'power2.out',
                scrollTrigger: { trigger: el as HTMLElement, start: 'top 88%' }
            });
        });

        // ── Table ──
        (gsap.utils.toArray('.table-wrap') as Element[]).forEach(el => {
            gsap.to(el, {
                opacity: 1, y: 0, duration: 0.7, ease: 'power2.out',
                scrollTrigger: { trigger: el as HTMLElement, start: 'top 88%' }
            });
        });

        // ── FAQ items ──
        (gsap.utils.toArray('.faq-item') as Element[]).forEach((el, i) => {
            gsap.to(el, {
                opacity: 1, y: 0, duration: 0.55, ease: 'power2.out',
                delay: i * 0.07,
                scrollTrigger: { trigger: el as HTMLElement, start: 'top 90%' }
            });
        });

        // ── CTA ──
        gsap.to('#cta-section', {
            opacity: 1, y: 0, duration: 0.9, ease: 'power3.out',
            scrollTrigger: { trigger: '#cta-section', start: 'top 85%' }
        });

        // ── Reading progress bar ──
        const bar = document.getElementById('progress-bar');
        if (bar) {
            ScrollTrigger.create({
                trigger: '.article-body',
                start: 'top 80%',
                end: 'bottom bottom',
                onUpdate: (self) => { bar.style.width = (self.progress * 100) + '%'; }
            });
        }

        // ── TOC active link ──
        const sections = document.querySelectorAll('section[id]');
        const tocLinks = document.querySelectorAll('.toc-list a');
        sections.forEach(section => {
            ScrollTrigger.create({
                trigger: section,
                start: 'top 40%',
                end: 'bottom 40%',
                onEnter: () => setActive(section.id),
                onEnterBack: () => setActive(section.id),
            });
        });
        function setActive(id: string) {
            tocLinks.forEach(a => {
                a.classList.toggle('active', a.getAttribute('href') === '#' + id);
            });
        }
    </script>
