    <style>
        /* ── Reset & tokens ── */
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        * { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
        html { scroll-behavior: smooth; }

        :root {
            --bg:       #06080f;
            --surface:  #0d0d0d;
            --surface2: #141414;
            --text:     #ffffff;
            --text-dim: rgba(255,255,255,0.96);
            --text-muted: rgba(255,255,255,0.62);
            --accent:   #c8c4b8;
            --accent2:  #a09890;
            --border:   rgba(255,255,255,0.08);
            --border2:  rgba(255,255,255,0.14);
            --gold:     #b8a882;
            --glass:    rgba(255,255,255,0.04);
        }

        body {
            background-image:
                linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.65)),
                url('https://pub-ac7fa03922994ab2902c13fc622c5987.r2.dev/blog/ultimate-guide-interior-designer-websites/atelierevo-blog-hero-bg.jpg');
            background-attachment: fixed;
            background-size: cover;
            background-position: center 40%;
            color: var(--text);
            font-family: 'Inter', sans-serif;
            font-size: 17px;
            line-height: 1.8;
            overflow-x: hidden;
        }

        /* ── Hero ── */
        .post-hero {
            position: relative;
            width: 100%;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            z-index: 2;
        }
        .hero-bg-overlay {
            display: none;
        }
        .hero-content {
            position: relative;
            z-index: 2;
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
            padding: 0 4rem 6rem;
        }
        .hero-eyebrow {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            margin-bottom: 2rem;
            opacity: 0;
            transform: translateY(20px);
        }
        .hero-category {
            font-family: 'Michroma', sans-serif;
            font-size: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 0.45em;
            color: var(--gold);
            background: rgba(184,168,130,0.12);
            border: 1px solid rgba(184,168,130,0.25);
            border-radius: 99px;
            padding: 5px 14px;
        }
        .hero-sep {
            width: 40px; height: 1px;
            background: rgba(255,255,255,0.2);
        }
        .hero-meta-text {
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.25em;
            color: var(--text-muted);
        }
        .hero-title {
            font-family: 'Michroma', sans-serif;
            font-size: clamp(2.2rem, 5.5vw, 5rem);
            text-transform: uppercase;
            letter-spacing: -0.02em;
            line-height: 1.05;
            color: #fff;
            max-width: 900px;
            opacity: 0;
            transform: translateY(30px);
        }
        .hero-subtitle {
            margin-top: 2rem;
            font-size: clamp(1rem, 1.5vw, 1.2rem);
            font-weight: 300;
            color: rgba(255,255,255,0.82);
            max-width: 680px;
            line-height: 1.7;
            opacity: 0;
            transform: translateY(20px);
        }
        .hero-scroll-hint {
            margin-top: 4rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            font-family: 'Michroma', sans-serif;
            font-size: 0.58rem;
            letter-spacing: 0.4em;
            text-transform: uppercase;
            color: var(--text-muted);
            opacity: 0;
        }
        .hero-scroll-line {
            width: 40px; height: 1px;
            background: var(--border2);
        }

        /* ── Page wrapper ── */
        .page-wrap {
            position: relative;
            z-index: 2;
        }

        /* ── Widescreen layout: sidebar + content ── */
        .article-layout {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 4rem;
            display: grid;
            grid-template-columns: 240px 1fr;
            gap: 0 5rem;
            align-items: start;
        }

        /* ── Sticky TOC sidebar ── */
        .toc-sidebar {
            position: sticky;
            top: 6rem;
            padding: 2.5rem 0;
        }
        .toc-label {
            font-family: 'Michroma', sans-serif;
            font-size: 0.58rem;
            text-transform: uppercase;
            letter-spacing: 0.45em;
            color: var(--text-muted);
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        .toc-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }
        .toc-list {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0;
        }
        .toc-list a {
            display: block;
            padding: 0.55rem 0 0.55rem 1rem;
            border-left: 1px solid var(--border);
            font-size: 0.72rem;
            line-height: 1.4;
            color: var(--text-muted);
            text-decoration: none;
            transition: color 0.25s ease, border-color 0.25s ease;
        }
        .toc-list a:hover,
        .toc-list a.active {
            color: var(--accent);
            border-color: var(--accent2);
        }
        .toc-progress {
            margin-top: 2.5rem;
            height: 2px;
            background: var(--border);
            border-radius: 99px;
            overflow: hidden;
        }
        .toc-progress-bar {
            height: 100%;
            width: 0%;
            background: var(--gold);
            transition: width 0.1s linear;
        }

        /* ── Main content ── */
        .article-body {
            padding: 5rem 0 8rem;
            min-width: 0;
        }

        /* ── Section spacing ── */
        section {
            margin-bottom: 0;
        }
        section + section {
            margin-top: 6rem;
        }

        /* ── Typography ── */
        h2 {
            font-family: 'Michroma', sans-serif;
            font-size: clamp(1.15rem, 2.2vw, 1.7rem);
            text-transform: uppercase;
            letter-spacing: 0.04em;
            line-height: 1.25;
            color: #ffffff;
            text-shadow: 0 2px 24px rgba(0,0,0,0.6);
            margin-bottom: 2rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid var(--border);
            opacity: 0;
            transform: translateY(24px);
        }
        h2 .section-number {
            font-family: 'Playfair Display', serif;
            font-size: 0.7em;
            font-style: italic;
            color: var(--gold);
            margin-right: 0.75rem;
            font-weight: 400;
            text-transform: none;
            letter-spacing: 0;
        }
        h3 {
            font-family: 'Michroma', sans-serif;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: var(--accent);
            margin-top: 3rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        h3::before {
            content: '';
            width: 20px; height: 1px;
            background: var(--accent2);
            flex-shrink: 0;
        }
        p {
            font-size: 1rem;
            font-weight: 300;
            line-height: 1.85;
            color: var(--text-dim);
            margin-bottom: 1.5rem;
        }
        p:last-child { margin-bottom: 0; }
        a {
            color: var(--accent);
            text-decoration: underline;
            text-underline-offset: 3px;
            text-decoration-color: rgba(200,196,184,0.35);
            transition: color 0.2s, text-decoration-color 0.2s;
        }
        a:hover {
            color: #fff;
            text-decoration-color: rgba(255,255,255,0.5);
        }
        code {
            font-family: 'SF Mono', 'Fira Code', monospace;
            font-size: 0.85em;
            background: rgba(255,255,255,0.06);
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 2px 6px;
            color: var(--accent);
        }

        /* ── Introduction lead ── */
        .lead {
            font-size: 1.15rem;
            font-weight: 300;
            line-height: 1.8;
            color: rgba(232,232,228,0.92);
            margin-bottom: 1.5rem;
            border-left: 2px solid var(--gold);
            padding-left: 1.5rem;
        }

        /* ── Full-bleed section images ── */
        .section-image {
            width: calc(100% + 5rem);
            margin-left: -2.5rem;
            margin-right: -2.5rem;
            margin-top: 3rem;
            margin-bottom: 3rem;
            border-radius: 4px;
            overflow: hidden;
            position: relative;
        }
        .section-image img {
            width: 100%;
            height: auto;
            display: block;
            transition: transform 0.8s cubic-bezier(0.16,1,0.3,1);
        }
        .section-image:hover img { transform: scale(1.02); }
        .section-image figcaption {
            position: absolute;
            bottom: 0; left: 0; right: 0;
            padding: 0.75rem 1.25rem;
            background: linear-gradient(to top, rgba(5,5,5,0.7), transparent);
            font-size: 0.7rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.45);
        }

        /* ── Takeaways block ── */
        .takeaways {
            background: var(--surface);
            border: 1px solid var(--border);
            border-top: 2px solid var(--gold);
            border-radius: 0 0 8px 8px;
            padding: 2rem 2.5rem;
            margin: 2.5rem 0;
            opacity: 0;
            transform: translateY(20px);
        }
        .takeaways-label {
            font-family: 'Michroma', sans-serif;
            font-size: 0.58rem;
            text-transform: uppercase;
            letter-spacing: 0.45em;
            color: var(--gold);
            margin-bottom: 1.25rem;
        }
        .takeaways ul { list-style: none; }
        .takeaways li {
            position: relative;
            padding-left: 1.5rem;
            margin-bottom: 0.65rem;
            font-size: 0.9rem;
            font-weight: 300;
            color: var(--text-dim);
            line-height: 1.6;
        }
        .takeaways li:last-child { margin-bottom: 0; }
        .takeaways li::before {
            content: '→';
            position: absolute;
            left: 0;
            color: var(--gold);
            font-size: 0.8rem;
        }

        /* ── Data / pullquote ── */
        .data-point {
            margin: 3.5rem 0;
            padding: 2.5rem 3rem;
            position: relative;
            text-align: center;
            opacity: 0;
            transform: translateY(20px);
        }
        .data-point::before,
        .data-point::after {
            content: '';
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            width: 60px; height: 1px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
        }
        .data-point::before { top: 0; }
        .data-point::after  { bottom: 0; }
        .data-point-text {
            font-family: 'Playfair Display', serif;
            font-style: italic;
            font-size: clamp(1.2rem, 2.2vw, 1.7rem);
            color: #fff;
            line-height: 1.5;
            margin-bottom: 0.75rem;
        }
        .data-point-source {
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 0.25em;
            color: var(--text-muted);
        }

        /* ── Comparison table ── */
        .table-wrap {
            width: 100%;
            overflow-x: auto;
            margin: 2rem 0;
            border-radius: 8px;
            border: 1px solid var(--border);
            opacity: 0;
            transform: translateY(20px);
        }
        .comparison-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.88rem;
            background: var(--surface);
        }
        .comparison-table thead tr {
            background: var(--surface2);
        }
        .comparison-table th {
            padding: 1rem 1.25rem;
            text-align: left;
            font-family: 'Michroma', sans-serif;
            font-size: 0.62rem;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border2);
            white-space: nowrap;
        }
        .comparison-table th:first-child { color: var(--accent); }
        .comparison-table td {
            padding: 0.9rem 1.25rem;
            border-bottom: 1px solid var(--border);
            color: var(--text-dim);
            font-weight: 300;
            vertical-align: top;
        }
        .comparison-table td:first-child {
            font-weight: 500;
            color: var(--accent);
            white-space: nowrap;
        }
        .comparison-table tbody tr:last-child td { border-bottom: none; }
        .comparison-table tbody tr:hover td {
            background: rgba(255,255,255,0.02);
        }
        /* Best column highlight */
        .comparison-table td.best {
            color: rgba(184,168,130,0.9);
        }

        /* ── FAQ accordion style ── */
        .faq-list {
            margin-top: 1.5rem;
        }
        .faq-item {
            border-bottom: 1px solid var(--border);
            padding: 1.75rem 0;
            opacity: 0;
            transform: translateY(16px);
        }
        .faq-item:first-child { border-top: 1px solid var(--border); }
        .faq-question {
            font-family: 'Michroma', sans-serif;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #fff;
            line-height: 1.5;
            margin-bottom: 0.9rem;
        }
        .faq-answer {
            font-size: 0.95rem;
            font-weight: 300;
            color: var(--text-dim);
            line-height: 1.8;
        }

        /* ── CTA section ── */
        .cta-section {
            margin: 5rem 0;
            padding: 5rem 4rem;
            background: #fff;
            border-radius: 12px;
            text-align: center;
            position: relative;
            overflow: hidden;
            opacity: 0;
            transform: translateY(30px);
        }
        .cta-section::before {
            content: '';
            position: absolute;
            top: -60px; right: -60px;
            width: 200px; height: 200px;
            border-radius: 50%;
            background: rgba(0,0,0,0.04);
        }
        .cta-section::after {
            content: '';
            position: absolute;
            bottom: -40px; left: -40px;
            width: 150px; height: 150px;
            border-radius: 50%;
            background: rgba(0,0,0,0.03);
        }
        .cta-eyebrow {
            font-family: 'Michroma', sans-serif;
            font-size: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 0.45em;
            color: rgba(0,0,0,0.35);
            margin-bottom: 1.5rem;
        }
        .cta-section h2 {
            font-family: 'Michroma', sans-serif;
            font-size: clamp(1.3rem, 3vw, 2.2rem);
            text-transform: uppercase;
            letter-spacing: -0.01em;
            color: #000;
            border: none;
            padding: 0;
            margin-bottom: 1.5rem;
            opacity: 1;
            transform: none;
        }
        .cta-section p {
            font-size: 1rem;
            color: rgba(0,0,0,0.55);
            max-width: 560px;
            margin: 0 auto 1rem;
        }
        .cta-button {
            display: inline-flex;
            align-items: center;
            gap: 1rem;
            background: #000;
            color: #fff;
            padding: 1rem 2.5rem;
            text-decoration: none;
            font-family: 'Michroma', sans-serif;
            font-size: 0.7rem;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            margin-top: 2rem;
            border-radius: 2px;
            transition: transform 0.3s ease, gap 0.3s ease;
            position: relative;
            z-index: 1;
        }
        .cta-button:hover {
            transform: translateY(-2px);
            gap: 1.5rem;
            color: #fff;
            text-decoration: none;
        }
        .cta-arrow {
            font-size: 1rem;
            transition: transform 0.3s ease;
        }
        .cta-button:hover .cta-arrow { transform: translateX(4px); }

        /* ── Author bio ── */
        .author-bio {
            padding: 3.5rem 0;
            border-top: 1px solid var(--border);
            display: grid;
            grid-template-columns: auto 1fr;
            gap: 2rem;
            align-items: start;
        }
        .author-avatar {
            width: 56px; height: 56px;
            border-radius: 50%;
            background: var(--surface2);
            border: 1px solid var(--border2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Michroma', sans-serif;
            font-size: 0.7rem;
            color: var(--accent2);
            flex-shrink: 0;
        }
        .author-name {
            font-family: 'Michroma', sans-serif;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            color: var(--accent);
            margin-bottom: 0.5rem;
        }
        .author-bio p {
            font-size: 0.88rem;
            margin-bottom: 0.75rem;
        }

        /* ── Post footer ── */
        .post-footer {
            padding: 3rem 0 5rem;
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 2rem;
            flex-wrap: wrap;
        }
        .back-link {
            font-family: 'Michroma', sans-serif;
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 0.3em;
            color: var(--text-muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            transition: color 0.2s, gap 0.2s;
        }
        .back-link:hover { color: var(--accent); gap: 1.25rem; }
        .post-footer-copy {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        /* ── Mobile ── */
        @media (max-width: 1100px) {
            .article-layout {
                grid-template-columns: 1fr;
                padding: 0 2.5rem;
                gap: 0;
            }
            .toc-sidebar { display: none; }
            .section-image {
                width: 100%;
                margin-left: 0;
                margin-right: 0;
            }
        }
        @media (max-width: 768px) {
            .article-layout { padding: 0 1.5rem; }
            .hero-content { padding: 0 1.5rem 4rem; }
            .cta-section { padding: 3rem 1.5rem; }
            .author-bio { grid-template-columns: 1fr; }
            .post-footer { flex-direction: column; align-items: flex-start; }
        }
    </style>
