---
// src/pages/blog.astro
import '../styles/hero.css';
import Hero from '../components/Hero.jsx';
import Footer from '../components/Footer.astro';
import LenisScroll from '../components/LenisScroll.astro';

const posts = [
  {
    title: "Ultimate Guide to Interior Designer Websites: Everything You Need in 2026",
    slug: "ultimate-guide-interior-designer-websites",
    date: "May 16, 2026",
    description: "The complete guide to building an interior designer website that attracts high-value clients. Covers structure, portfolio design, SEO, and performance.",
    image: "https://pub-ac7fa03922994ab2902c13fc622c5987.r2.dev/blog/ultimate-guide-interior-designer-websites/atelierevo-ultimate-guide-interior-designer-websites-hero-01.webp",
    category: "Foundation"
  }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>Blog | Atelier Evo</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Michroma&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap">
  </head>
  <body class="bg-[#0a0a0a] text-[#f2f2f2]">
    
    <!-- Hero Section with Menu -->
    <div class="hero-slot h-[40vh] min-h-[400px]">
      <Hero client:only="react" />
    </div>

    <main class="max-w-7xl mx-auto px-6 py-24">
      <header class="mb-20">
        <h2 class="text-xs uppercase tracking-[0.3em] text-[#888] mb-4 font-['Michroma']">Insights & Strategy</h2>
        <h1 class="text-5xl md:text-7xl font-['Michroma'] uppercase leading-tight tracking-tighter">
          The Atelier <br/> <span class="italic text-[#d4d4d4]">Knowledge base.</span>
        </h1>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="group block">
            <div class="relative aspect-[16/10] overflow-hidden rounded-sm mb-6 bg-[#1a1a1a]">
              <img 
                src={post.image} 
                alt={post.title}
                class="object-cover w-full h-full transition-transform duration-700 group-hover:scale-105"
              />
              <div class="absolute top-4 left-4 bg-white/10 backdrop-blur-md px-3 py-1 text-[10px] uppercase tracking-widest text-white border border-white/20">
                {post.category}
              </div>
            </div>
            <div class="space-y-4">
              <div class="text-[10px] uppercase tracking-[0.2em] text-[#888]">{post.date}</div>
              <h3 class="text-xl font-['Michroma'] uppercase leading-snug group-hover:text-[#d4d4d4] transition-colors">
                {post.title}
              </h3>
              <p class="text-sm text-[#888] font-light line-clamp-3 leading-relaxed">
                {post.description}
              </p>
              <div class="pt-4 flex items-center gap-2 text-[10px] uppercase tracking-widest text-[#f2f2f2] group-hover:gap-4 transition-all">
                Read Article <span class="text-lg">→</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </main>

    <Footer />
    
    <LenisScroll />

    <style is:global>
      * {
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      
      .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
    </style>
  </body>
</html>
